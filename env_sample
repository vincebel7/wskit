# Timezone (IANA format, e.g. America/New_York, America/Chicago, UTC)
TZ=America/New_York

# MQTT credentials
# Used by the MQTT broker (to create the password file) and the subscriber (to connect).
# Collectors use these same credentials, hardcoded in collector.ino before flashing.
MQTT_PUB_USER=publisher
MQTT_PUB_PASS=replace-with-password
MQTT_SUB_USER=subscriber
MQTT_SUB_PASS=replace-with-password

# MySQL credentials
# Used by both the MySQL container (to initialize the database) and the subscriber (to connect).
# DB_HOST should stay as localhost when using the containerized MySQL service.
DB_HOST=127.0.0.1
DB_NAME=sensordata
DB_USER=
DB_PASS=
MYSQLDB_ROOT_PASSWORD=
